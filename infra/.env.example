# ============================================================
# Agent Harness — Environment Variables
# ============================================================
# MANDATORY: Fill in all variables marked REQUIRED before deployment.
# Copy to .env and set values: cp infra/.env.example infra/.env
# ============================================================

# --- Google Cloud ---
# REQUIRED: Google Cloud project ID
GOOGLE_CLOUD_PROJECT=
VERTEX_REGION=europe-west1

# Path to ADC credentials JSON (mounted into containers)
ADC_PATH=~/.config/gcloud/application_default_credentials.json

# --- PostgreSQL ---
POSTGRES_USER=harness
# REQUIRED: Change from default in production
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=harness

# --- Gateway ---
# REQUIRED: Comma-separated API keys in format "key1:caller1,key2:caller2"
GATEWAY_API_KEYS=
GATEWAY_PORT=8000
GATEWAY_RATE_LIMIT_MAX=100
GATEWAY_RATE_LIMIT_WINDOW=60

# --- DCE Backend ---
# REQUIRED: URL where DCE Backend REST API is accessible from the worker container
# Examples:
#   - http://localhost:8001 (DCE Backend outside Docker on same host)
#   - http://dce-backend:8001 (DCE Backend in Docker Compose service)
#   - http://10.0.0.5:8001 (DCE Backend on separate GCE VM)
DCE_BACKEND_URL=

# --- Optional ---
# STORAGE_ROOT=/data  (default, mounted volume)
# LOG_LEVEL=INFO
